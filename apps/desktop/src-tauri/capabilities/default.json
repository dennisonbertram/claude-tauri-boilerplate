{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/server",
          "sidecar": true,
          "args": ["--port", { "validator": "^\\d{4,5}$" }]
        }
      ]
    },
    "shell:allow-kill",
    "dialog:allow-open"
  ]
}
