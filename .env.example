# Server port — managed by init.sh, do not set manually
# PORT=3131

# Database location
# Default: ~/.claude-tauri/data.db  (shared across all clones on this machine)
# Set either variable to use a project-local DB that starts fresh on each clone:
#   DB_DIR=./data              (puts data.db inside ./data/)
#   DB_PATH=./data/data.db     (full explicit path)
#
# DB_DIR=./data

# Worktree base directory
# Default: ~/.claude-tauri/worktrees
# CLAUDE_TAURI_WORKTREE_BASE=./worktrees

# Google OAuth (Desktop app type — allows loopback redirect on any port)
# Create credentials at: https://console.cloud.google.com/apis/credentials
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
