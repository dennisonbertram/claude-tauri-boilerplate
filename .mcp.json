{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp@latest",
        "--browser",
        "chrome",
        "--output-dir",
        ".claude/browser-artifacts",
        "--save-session",
        "--save-video=1280x720"
      ],
      "type": "stdio"
    },
    "agentation": {
      "command": "npx",
      "args": [
        "-y",
        "agentation-mcp",
        "server"
      ],
      "type": "stdio"
    }
  }
}
